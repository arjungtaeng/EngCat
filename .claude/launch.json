{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "expo",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start", "--prefix", "mobile"],
      "port": 8081
    },
    {
      "name": "expo-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "web", "--prefix", "mobile"],
      "port": 8081
    },
    {
      "name": "site",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "--bind", "127.0.0.1"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
